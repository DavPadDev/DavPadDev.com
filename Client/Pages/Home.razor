@page "/"

<div class="home-container">

    <!-- Hero / Banner -->
    <section class="page-hero fade-in delay-0">
        <p class="page-eyebrow">Full-Stack Web Development</p>

        <h1>Welcome to my Portfolio</h1>

        <p class="page-intro">
            Building real-world web applications with clean UI, practical functionality,
            and production-ready deployment.
        </p>

    </section>

    <!-- About Blurb -->
    <section class="about-preview fade-in delay-1">
        <div class="section-header">
            <h2>About Me</h2>
            <a class="section-link" href="/about">Read more →</a>
        </div>

        <div class="about-grid">
            <img class="about-photo"
                 src="images/davidpadilla-portrait.jpg"
                 alt="Portrait of David Padilla" />

            <div class="about-copy">
                <p>
                    I'm a passionate developer focused on building clean, scalable web applications with real-world functionality and modern cloud tools.
                </p>

                <ul class="about-bullets">
                    <li>Building full-stack web applications with Blazor, .NET, and Azure</li>
                    <li>Designing clean, responsive interfaces with a focus on usability and structure</li>
                    <li>Developing scalable, maintainable systems with real-world integrations</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Projects Preview -->
    <section class="projects-preview fade-in delay-2">
        <div class="section-header">
            <h2>Highlighted Projects</h2>
            <a class="section-link" href="/projects">See all →</a>
        </div>

        <div class="projects-grid">
            <article class="project-card">
                <div class="project-image-wrap">
                    <img src="images/stellashairstudio-home.png"
                         alt="Screenshot of Stella's Hair Studio homepage"
                         class="project-image" />
                </div>

                <div class="project-card-body">
                    <h3>Stella’s Hair Studio</h3>

                    <p>
                        A client website rebuilt with a polished salon-focused design, service showcase,
                        stylist pages, and a working contact flow for a real business. This project highlights front-end polish,
                        branding, and real client-oriented development.
                    </p>

                    <div class="project-links">
                        <a href="/projects">Details →</a>
                    </div>
                </div>
            </article>

            <article class="project-card">
                <div class="project-image-wrap">
                    <img src="images/mealtracker-home.png"
                         alt="Screenshot of MealTracker prototype homepage"
                         class="project-image" />
                </div>

                <div class="project-card-body">
                    <h3>Kitchen Today</h3>

                    <p>
                        A pantry-first meal planning application that helps users see what they can cook,
                        track ingredients on hand, and make practical cooking decisions faster.
                    </p>

                    <div class="project-links">
                        <a href="/projects">Details →</a>
                    </div>
                </div>
            </article>
        </div>

        <div class="projects-link">
            <a class="btn" href="/projects">See All Projects</a>
        </div>
    </section>

    <!-- Call-to-Action -->
    <PageCta Center="true" Class="fade-in delay-3" />
</div>
